# summarizer/.env
# Copy to .env and fill in values. This file is committed; .env is gitignored.

# ── Obsidian ──────────────────────────────────────────────────────────────────
# Path to the folder containing your year folders (2025/, 2026/, etc.)
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian/Journal

# Filename marker used to detect and name summary files (default: Summary)
# Weekly:    2026-W18-Summary.md
# Quarterly: 2026-Q1-Summary.md
SUMMARY_FILENAME_PREFIX=Summary

# ── AI provider ───────────────────────────────────────────────────────────────
# "anthropic" (default) or "openai"
AI_PROVIDER=anthropic

# Anthropic — get key at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-yourKeyHere

# OpenAI-compatible (GitHub Models / Copilot)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://models.inference.ai.azure.com
# AI_MODEL=gpt-4o

# ── Repository API tokens ─────────────────────────────────────────────────────────────
# One var per account. Names are referenced in accounts.json via "tokenEnvVar".
# Tokens need: repo, read:org scopes.
# For GHE with SSO: also authorize the token for your org after creation.

TOKEN_GHE=ghp_yourGHETokenHere
TOKEN_GITHUB=ghp_yourGithubTokenHere
# TOKEN_BITBUCKET=ATATT3yourBitbucketTokenHere

# GitHub Enterprise (GHE) rate limit check:
#curl -H "Authorization: Bearer <GHE_TOKEN>" https://force.ghe.com/api/v3/rate_limit

# GitHub rate limit check:
#curl -H "Authorization: Bearer <GITHUB_TOKEN>" https://api.github.com/rate_limit

# Bitbucket rate limit check:
#curl -u "you@example.com:<BITBUCKET_TOKEN>" https://api.bitbucket.org/2.0/user
