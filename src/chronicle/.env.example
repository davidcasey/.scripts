# chronicle/.env
# Copy to .env and fill in values. This file is committed; .env is gitignored.

# ── Obsidian ──────────────────────────────────────────────────────────────────
# Path to the folder containing your year folders (2025/, 2026/, etc.)
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian/Journal

# Filename marker used to detect and name summary files (default: Summary)
# Weekly:    2026-W18-Summary.md
# Quarterly: 2026-Q1-Summary.md
SUMMARY_FILENAME_PREFIX=Summary

# ── Team heartbeat (summary-team-weekly / summary-team-quarterly) ─────────────
# Output root for the team heartbeat digests, a separate area from your journal.
# Defaults to "<vault parent>/Team/Heartbeat" if unset.
OBSIDIAN_TEAM_PATH=~/Documents/Obsidian/Team/Heartbeat
# Filename marker for team files (default: Heartbeat) → 2026-W27-Heartbeat.md
TEAM_SUMMARY_FILENAME_SUFFIX=Heartbeat
# Max PRs per classification call. The heartbeat classifies PRs in bounded
# batches so busy weeks and small local context windows don't overflow. Lower it
# (e.g. 8) for small local models; raise it for large-context cloud models. Default: 15
TEAM_BATCH_SIZE=15
# Writing-style guide injected into the summary prompts so prose follows house
# style. Defaults to .github/instructions/writing-style.instructions.md if present.
# TEAM_STYLE_FILE=~/path/to/style.md
# Append a "Taxonomy Suggestions" section proposing new/split domains when a
# domain dominates or Uncategorized shows a theme. Set to false to disable. Default: true
TEAM_SUGGEST_DOMAINS=true
# Roster + domain→repo mapping live in team.json (gitignored). Host/org/token
# are reused from the "type": "ghe" account in accounts.json — no separate token.

# ── L24 daily digest (summary-l24.mjs) ────────────────────────────────────────
# Summarizes the previous business day (AI conversations + authored PRs) into an
# "## L24" section of today's journal note; calendar meetings are a sub-list.
# Outlook published calendar feed. SECRET: anyone with this URL can read your calendar.
CALENDAR_ICS_URL=https://outlook.office365.com/owa/calendar/<id>/calendar.ics
# Max accomplishment bullets (default: 10). Meetings are separate and not counted.
L24_MAX_BULLETS=10
# Override only if your AI chat history lives outside the defaults:
# CLAUDE_PROJECTS_DIR=~/.claude/projects
# VSCODE_STORAGE_DIR=~/Library/Application Support/Code/User/workspaceStorage

# ── AI provider ───────────────────────────────────────────────────────────────
# "anthropic" (default), "openai", or "ollama"
AI_PROVIDER=anthropic

# Anthropic — get key at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-yourKeyHere

# OpenAI-compatible (GitHub Models / Copilot)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://models.inference.ai.azure.com
# AI_MODEL=gpt-4o

# Ollama (local, free, no key). Defaults: base http://localhost:11434/v1, model llama3.1
# Slower but runs offline — good for grinding through backfills overnight.
#   AI_PROVIDER=ollama
#   AI_MODEL=qwen2.5:14b          # override; larger models write better narrative
#   OPENAI_BASE_URL=http://localhost:11434/v1   # only if Ollama is on another host/port

# ── Repository API tokens ─────────────────────────────────────────────────────────────
# One var per account. The NAME of each var must match its "tokenEnvVar" in
# accounts.json (so these are examples — use whatever names your accounts.json references).
# Tokens need: repo, read:org scopes. For GHE with SSO: authorize the token for your org.

# TOKEN_GHE=ghp_yourGHETokenHere
# TOKEN_GITHUB=ghp_yourGithubTokenHere
# TOKEN_BITBUCKET=ATATT3yourBitbucketTokenHere

# GitHub Enterprise (GHE) rate limit check:
#curl -H "Authorization: Bearer <GHE_TOKEN>" https://force.ghe.com/api/v3/rate_limit

# GitHub rate limit check:
#curl -H "Authorization: Bearer <GITHUB_TOKEN>" https://api.github.com/rate_limit

# Bitbucket rate limit check:
#curl -u "you@example.com:<BITBUCKET_TOKEN>" https://api.bitbucket.org/2.0/user
